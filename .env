# ==============================================================================
# Server Health Monitor — Environment Variables
# Copy to .env and fill in your values.
# ==============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5433
DB_NAME=server_monitor
DB_USER=postgres
DB_PASSWORD=postgres

# ── Monitored Servers (comma-separated container names) ──────────────────────
SERVERS=sim-server-1,sim-server-2,sim-server-3

# ── Collection Interval (seconds) ───────────────────────────────────────────
COLLECT_INTERVAL=300

# ── Thresholds (percent) ────────────────────────────────────────────────────
THRESHOLD_CPU=85.0
THRESHOLD_MEM=90.0
THRESHOLD_DISK=90.0

# ── Email Alerts (optional — leave blank to skip) ───────────────────────────
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
ALERT_FROM=
ALERT_TO=

# ── Slack Alerts (optional — leave blank to skip) ───────────────────────────
SLACK_WEBHOOK_URL=

# ── Dashboard ───────────────────────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=5050
